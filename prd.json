            "createdAt": "timestamp",
            "email": "string",
            "emailVerified": "boolean",
            "id": "UUID",
            "lastActive": "timestamp",
            "name": "string",
            "password": "string",
            "provider": "string",
            "providerId": "string",
            "resetPasswordExpires": "timestamp",
            "resetPasswordToken": "string",
            "role": "string",
            "status": "string"
          },
          "relationships": [
            "Users hasMany subscriptions",
            "Users hasMany activities"

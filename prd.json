          "startDate",
          "endDate",
          "onChange",
          "presets"
        ]
      },
      {
        "component_name": "authForm",
        "type": "shared",
        "used_on": [
          "login",
          "register",
          "forgotPassword",
          "resetPassword"
        ],
        "purpose": "Reusable authentication form wrapper with validation",

          "provider",
          "onClick",
          "loading"
        ]
      },
      {
        "component_name": "passwordInput",
        "type": "shared",
        "used_on": [
          "login",
          "register",
          "resetPassword"
        ],
        "purpose": "Password input field with show/hide toggle and strength indicator",
        "props": [
          "value",
          "onChange",
          "showStrength",
          "confirmValue"
        ]
      },
      {
        "component_name": "authProvider",
        "type": "shared",
        "used_on": [
          "all"
        ],
        "purpose": "Authentication context provider for managing JWT tokens and user state",

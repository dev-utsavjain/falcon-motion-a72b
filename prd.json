{
  "project_metadata": {
    "project_name": "hi",
    "project_category": "SaaS",
    "description": "A comprehensive dashboard for managing SaaS products, users, analytics, and settings with real-time data visualization and team collaboration features.",
    "core_purpose": "Provide SaaS founders and teams with a centralized hub to monitor, manage, and grow their product.",
    "target_audience": "Founders",
    "key_features": [
      "Real-time analytics",
      "User management",
      "Revenue tracking",
      "Team collaboration",
      "API monitoring",
      "Customizable widgets",
      "Multi-tenant support",
      "Notification center",
      "User authentication",
      "Social login",
      "Password reset",
      "JWT token authentication",
      "Automatic token refresh",
      "Protected API routes"
    ]
  },
  "frontend": {
    "pages": [
      {
        "page_name": "dashboard",
        "route": "/",
        "show_in_nav": true,
        "nav_order": 1,
        "purpose": "Main dashboard showing key metrics, charts, and quick actions for the SaaS product",
        "sections": [
          "Header with user profile dropdown",
          "KPI cards (MRR, Active Users, Churn Rate, Growth)",
          "Revenue chart with time range selector",
          "User activity heatmap",
          "Recent activity feed",
          "Quick action buttons (Add User, View Reports, Settings)",
          "Customizable widget grid",
          "Notification bell with badge"
        ],
        "content_notes": "Dashboard serves as the main hub. KPI cards should show live data with trend indicators (up/down arrows). Revenue chart defaults to last 30 days with ability to switch ranges. Activity feed shows latest 5 events with timestamps. Widget grid allows drag-and-drop rearrangement. All data refreshes every 30 seconds. Use Framer Motion for smooth transitions when data updates.",
        "data_needs": [
          "/api/metrics",
          "/api/revenue",
          "/api/activity",
          "/api/notifications"
        ],
        "is_protected": true
      },
      {
        "page_name": "users",
        "route": "/users",
        "show_in_nav": true,
        "nav_order": 2,
        "purpose": "Manage users, view user details, handle subscriptions and permissions",
        "sections": [
          "User table with search and filters",
          "User profile modal",
          "Subscription status badges",
          "Role management dropdown",
          "Bulk actions toolbar",
          "Add user button",
          "Export users button",
          "Pagination controls"
        ],
        "content_notes": "User table includes columns: Name, Email, Status, Role, Created Date, Last Active. Search filters by name/email. Status shows Active/Inactive/Pending. Role dropdown allows Admin/User/Guest selection. Bulk actions include activate/deactivate/delete. Add user opens modal with form validation. Export generates CSV. Table supports sorting and pagination (20 users per page).",
        "data_needs": [
          "/api/users",
          "/api/users/search",
          "/api/users/:id",
          "/api/users/bulk-actions"
        ],
        "is_protected": true
      },
      {
        "page_name": "analytics",
        "route": "/analytics",
        "show_in_nav": true,
        "nav_order": 3,
        "purpose": "Deep dive into product analytics with custom reports and data visualization",
        "sections": [
          "Analytics header with date picker",
          "Traffic sources pie chart",
          "User retention cohort chart",
          "Feature usage bar chart",
          "Custom report builder",
          "Export report button",
          "Real-time visitors counter",
          "Geographic distribution map"
        ],
        "content_notes": "Analytics page provides comprehensive insights. Date picker defaults to last 7 days with preset ranges. Traffic sources show Direct, Organic, Referral, Social percentages. Retention cohort shows weekly return rates. Feature usage displays top 10 features by usage count. Report builder allows selecting metrics and time ranges. All charts use Framer Motion for smooth transitions. Map shows user distribution with country hover effects.",
        "data_needs": [
          "/api/analytics/traffic",
          "/api/analytics/retention",
          "/api/analytics/features",
          "/api/analytics/reports"
        ],
        "is_protected": true
      },
      {
        "page_name": "settings",
        "route": "/settings",
        "show_in_nav": true,
        "nav_order": 4,
        "purpose": "Configure product settings, billing, team members, and integrations",
        "sections": [
          "Settings navigation tabs",
          "General settings form",
          "Billing information section",
          "Team members list",
          "Integrations marketplace",
          "API keys management",
          "Notification preferences",
          "Danger zone for account actions"
        ],
        "content_notes": "Settings uses tabbed interface: General, Billing, Team, Integrations, API, Notifications. General includes company name, timezone, language. Billing shows current plan, payment method, invoice history. Team shows members with role management and invitation system. Integrations lists available services with toggle switches. API keys shows active keys with copy and regenerate options. Danger zone includes delete account with confirmation modal. All forms have validation and save indicators.",
        "data_needs": [
          "/api/settings",
          "/api/billing",
          "/api/team",
          "/api/integrations",
          "/api/api-keys"
        ],
        "is_protected": true
      },
      {
        "page_name": "notifications",
        "route": "/notifications",
        "show_in_nav": false,
        "nav_order": 0,
        "purpose": "View and manage all notifications, alerts, and system messages",
        "sections": [
          "Notification filters (All, Unread, Alerts, Updates)",
          "Notification list with timestamps",
          "Mark as read/unread actions",
          "Notification preferences link",
          "Clear all button",
          "Infinite scroll for notifications"
        ],
        "content_notes": "Notification center shows all system alerts. Filters allow viewing by type. Each notification shows icon, title, message, timestamp, and read status. Swipe actions on mobile for mark read/delete. Preferences link opens settings modal. Clear all shows confirmation. Infinite scroll loads 20 notifications at a time. Unread count shows in header bell icon.",
        "data_needs": [
          "/api/notifications",
          "/api/notifications/mark-read",
          "/api/notifications/clear"
        ],
        "is_protected": true
      },
      {
        "page_name": "login",
        "route": "/login",
        "show_in_nav": false,
        "nav_order": 0,
        "purpose": "User authentication page with email/password login and social login options",
        "sections": [
          "Logo and app name",
          "Email input field",
          "Password input field with show/hide toggle",
          "Remember me checkbox",
          "Forgot password link",
          "Login button",
          "Social login divider",
          "Google login button",
          "Sign up link"
        ],
        "content_notes": "Login page should be clean and minimal. Form validation for email format and required fields. Remember me persists login session. Forgot password links to password reset page. Social login uses Google OAuth. Include loading states and error messages. Redirect to dashboard on successful login. Store JWT token in localStorage with automatic attachment via Axios interceptors.",
        "data_needs": [
          "/api/auth/login",
          "/api/auth/google"
        ],
        "is_protected": false
      },
      {
        "page_name": "register",
        "route": "/register",
        "show_in_nav": false,
        "nav_order": 0,
        "purpose": "User registration page for creating new accounts",
        "sections": [
          "Logo and app name",
          "Name input field",
          "Email input field",
          "Password input field with strength indicator",
          "Confirm password input field",
          "Terms and conditions checkbox",
          "Sign up button",
          "Social signup divider",
          "Google signup button",
          "Login link"
        ],
        "content_notes": "Registration form with real-time validation. Password strength indicator shows weak/medium/strong. Confirm password must match. Terms checkbox required. Show success message and redirect to login on completion. Include client-side validation and error handling. Store JWT token in localStorage after successful registration.",
        "data_needs": [
          "/api/auth/register",
          "/api/auth/google"
        ],
        "is_protected": false
      },
      {
        "page_name": "forgotPassword",
        "route": "/forgot-password",
        "show_in_nav": false,
        "nav_order": 0,
        "purpose": "Password reset request page",
        "sections": [
          "Logo and app name",
          "Instructions text",
          "Email input field",
          "Send reset link button",
          "Back to login link",
          "Success message area"
        ],
        "content_notes": "Simple form for requesting password reset. Clear instructions about checking email. Success message shows after submission. Include rate limiting message. Link back to login page.",
        "data_needs": [
          "/api/auth/forgot-password"
        ],
        "is_protected": false
      },
      {
        "page_name": "resetPassword",
        "route": "/reset-password/:token",
        "show_in_nav": false,
        "nav_order": 0,
        "purpose": "Password reset confirmation page",
        "sections": [
          "Logo and app name",
          "New password input field",
          "Confirm new password input field",
          "Reset password button",
          "Password requirements hint",
          "Success message area"
        ],
        "content_notes": "Form for setting new password using reset token from email. Show password requirements. Confirm password must match. Success message and redirect to login after completion.",
        "data_needs": [
          "/api/auth/reset-password"
        ],
        "is_protected": false
      }
    ],
    "navigation": {
      "type": "header",
      "position": "sticky",
      "style": "horizontal",
      "has_logo": true,
      "has_search": true,
      "extra_items": [
        "Notifications",
        "Profile",
        "Logout"
      ]
    },
    "theme": {
      "design_dna": "LINEAR_MODERN",
      "color_scheme": "dark",
      "primary_color": "#5E6AD2",
      "secondary_color": "#7C3AED",
      "accent_color": "#00D4FF",
      "font_family": "Inter",
      "font_type": "sans",
      "border_radius": "lg",
      "shadow_style": "medium",
      "animation_style": "moderate",
      "interaction_style": "subtle"
    },

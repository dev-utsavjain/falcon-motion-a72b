        "purpose": "Route wrapper that checks for valid JWT token before rendering",
        "props": [
          "children",
          "redirectTo"
        ]
      },
      {
        "component_name": "apiClient",
        "type": "shared",
        "used_on": [
          "all"
        ],
        "purpose": "Axios instance with interceptors for token attachment and refresh logic",
        "props": []
      }
